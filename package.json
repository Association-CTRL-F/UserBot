{
	"name": "userbot",
	"version": "26.4.3",
	"description": "UserBot",
	"type": "module",
	"main": "src/index.js",
	"scripts": {
		"start": "node .",
		"lint": "eslint src",
		"format:check": "prettier --check \"src/**/*.js\"",
		"format": "prettier --write \"src/**/*.js\"",
		"test": "npm run lint && npm run format:check",
		"docker-start": "docker-compose -f ./docker/docker-compose.yml up -d",
		"docker-stop": "docker-compose -f ./docker/docker-compose.yml down",
		"docker-compose-build-start": "docker-compose -f ./docker/docker-compose-build.yml up -d --build",
		"docker-compose-build-stop": "docker-compose -f ./docker/docker-compose-build.yml down"
	},
	"dependencies": {
		"bent": "^7.3.12",
		"chatgpt": "^5.2.5",
		"discord.js": "^14.22.1",
		"mathjs": "^15.0.0",
		"ms": "^2.1.3",
		"mysql2": "^3.22.3",
		"node-fetch": "^2.6.7",
		"pagination.djs": "^4.0.18"
	},
	"devDependencies": {
		"dotenv": "^17.4.2",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"prettier": "^3.6.2"
	},
	"engines": {
		"node": ">=20.2.0"
	}
}