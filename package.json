{
	"name": "userbot",
	"version": "25.7.7",
	"description": "UserBot",
	"main": "src/index.js",
	"scripts": {
		"dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
		"build": "tsc",
		"start": "node src/index.js",
		"lint": "eslint .",
		"format": "prettier --write .",
		"typecheck": "tsc --noEmit",
		"check": "pnpm run lint && pnpm run typecheck",
		"migrate": "kysely migrate:latest",
		"migrate:down": "kysely migrate:down",
		"migrate:create": "kysely migrate:make",
		"migrate:list": "kysely migrate:list",
		"seed:run": "kysely seed:run",
		"seed:make": "kysely seed:make",
		"sql": "kysely sql",
		"postinstall": "pnpm run format",
		"postuninstall": "pnpm run format"
	},
	"imports": {
		"#app/*": "./src/app/*.ts",
		"#lib/*": "./src/lib/*.ts",
		"#database/*": "./src/database/*.ts",
		"#repository/*": "./src/repository/*.ts",
		"#services/*": "./src/services/*.ts"
	},
	"dependencies": {
		"@sapphire/discord.js-utilities": "^7.3.3",
		"@sapphire/framework": "^5.4.0",
		"@sapphire/pieces": "^4.4.1",
		"@sapphire/plugin-logger": "^4.1.0",
		"@sapphire/plugin-subcommands": "^7.0.1",
		"@sapphire/utilities": "^3.18.2",
		"colorette": "^2.0.20",
		"discord.js": "~14.25.0",
		"dotenv": "^17.2.3",
		"envalid": "^8.1.1",
		"kysely": "^0.28.8",
		"pg": "^8.16.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@eslint/json": "^0.14.0",
		"@types/node": "^24.10.1",
		"@types/pg": "^8.15.6",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"globals": "^16.5.0",
		"kysely-ctl": "^0.19.0",
		"prettier": "^3.6.2",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	},
	"type": "module",
	"volta": {
		"node": "24.10.0"
	}
}
